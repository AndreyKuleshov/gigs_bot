# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Must match one of the Authorized redirect URIs in Google Cloud Console
# Local:            http://localhost:8000/auth/google/callback
# PythonAnywhere:   https://username.pythonanywhere.com/auth/google/callback
# Fly.io:           https://gigs-bot.fly.dev/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, works everywhere with no setup):
DATABASE_URL=sqlite+aiosqlite:///./gigs_bot.db
# PostgreSQL (Docker / Fly.io):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/gigs_bot

# ── Token encryption ──────────────────────────────────────────────────────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ── Webhook (required for PythonAnywhere; leave empty for local long-polling) ──
# Generate secret: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_URL=https://username.pythonanywhere.com
WEBHOOK_SECRET=your_webhook_secret_here

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
